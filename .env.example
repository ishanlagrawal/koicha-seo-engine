# =============================================================
# KOICHA SEO ENGINE — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# =============================================================

# --- GOOGLE AI ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- GOOGLE CLOUD ---
GOOGLE_CLOUD_PROJECT_ID=credible-spark-465804-j5
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- GOOGLE MAPS ---
GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# --- GOOGLE SHEETS ---
# Dashboard sheet ID (create a new Google Sheet and paste its ID)
KOICHA_SHEET_ID=your_koicha_dashboard_sheet_id

# --- GOOGLE BUSINESS PROFILE ---
# OAuth token path (generated after first login)
GBP_TOKEN_PATH=config/gbp_token.json
GBP_CREDENTIALS_PATH=config/gbp_credentials.json

# --- GOOGLE SEARCH CONSOLE ---
SEARCH_CONSOLE_SITE_URL=https://ishan-agrawal.github.io/koicha-seo-engine

# --- TELEGRAM BOT ---
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_personal_chat_id

# --- BLOGGER ---
BLOGGER_BLOG_ID=your_blogger_blog_id

# --- SITE ---
SITE_BASE_URL=https://ishan-agrawal.github.io/koicha-seo-engine
SITE_OUTPUT_DIR=site/
